# RETICLE FastAPI — environment template.
# Copy to `.env` and fill in your values. Never commit the real .env.
#
# RDS connection (same values as prototype/.env):
# Leave AWS_DB_HOST blank to skip Postgres and run without a DB backend.
AWS_DB_HOST     = <rds-endpoint>.rds.amazonaws.com
AWS_DB_PORT     = 5432
AWS_DB_USER     = <db-user>
AWS_DB_PASSWORD = <db-password>
AWS_DB_NAME     = <db-name>
