# RETICLE prototype — environment template.
# Copy to `.env` and fill in your own values. NEVER commit the real .env
# (it is git-ignored). This repo is public, so no real keys/IDs belong here.

# --- WashU AI gateway (OAuth2 client-credentials -> OpenAI-compatible chat) ---
# Used by the LLM directionality step and the web app's "AI reading".
# Docs: https://it.wustl.edu/items/secure-api-access-to-ai-endpoints/
# Network: WashU-only — you must be on campus or the WashU VPN.
WASHU_CLIENT_ID      = <your-azure-ad-client-id>
WASHU_CLIENT_SECRET  = <your-client-secret>          # SECRET — keep out of git
WASHU_TENANT_ID      = <your-tenant-id>
WASHU_SCOPE          = api://<gateway-app-id>/.default
WASHU_TOKEN_URL      = https://login.microsoftonline.com/<your-tenant-id>/oauth2/v2.0/token
WASHU_CHAT_URL       = https://api.openai.wustl.edu/models/v1/chat/completions
WASHU_MODEL          = gpt-4o                          # AI reading uses gpt-5 (set per-call)

# --- NCBI E-utilities (PubMed counts + abstracts for darkness & RAG) ---
# OPTIONAL. Without a key you are rate-limited to 3 req/s (10 req/s with one).
# Get a free key: NCBI account -> Settings -> API Key Management.
NCBI_API_KEY         = <your-ncbi-api-key>

# --- Team AWS RDS (PostgreSQL) ---
# OPTIONAL. If set, the web app reads from RDS (schema `reticle`) instead of the
# local SQLite file. Leave AWS_DB_HOST blank to run fully local on SQLite.
AWS_DB_HOST          = <rds-endpoint>.rds.amazonaws.com
AWS_DB_PORT          = 5432
AWS_DB_USER          = <db-user>
AWS_DB_PASSWORD      = <db-password>          # SECRET — keep out of git
AWS_DB_NAME          = <db-name>
