# RETICLE Database Configuration
# Copy this file to .env and fill in with your actual values

# ============================================================================
# PostgreSQL Database (AWS RDS)
# ============================================================================
DB_HOST=reticle-db.XXXXXXXXXXXXX.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=reticle_admin
DB_PASSWORD=your_secure_password_here
DB_NAME=reticle_biogrid

# ============================================================================
# BioGrid ORCS Configuration
# ============================================================================
BIOGRID_BASE_URL=https://orcs.thebiogrid.org
BIOGRID_ORGANISMS=Homo sapiens,Mus musculus
BIOGRID_TIMEOUT=60
BIOGRID_MAX_RETRIES=3

# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_DIR=./data
BATCH_SIZE=1000

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=us-east-1
AWS_RDS_INSTANCE_ID=reticle-db
