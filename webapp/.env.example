# Copy to .env for local dev. All REACT_APP_* vars are baked into the bundle at
# build time (public — never put secrets here).
REACT_APP_API_BASE_URL=http://localhost:8000

# Public Entra SSO identifiers used by MSAL.js. When set, the SPA initialises
# login directly and never calls the backend for config. If omitted, the app
# falls back to fetching GET /api/auth/config from the API (AWS-sourced).
REACT_APP_SSO_CLIENT_ID=<azure-app-client-id>
REACT_APP_SSO_TENANT_ID=<azure-tenant-id>
# Optional overrides (defaults: authority from tenant id; redirect URI = app origin)
# REACT_APP_SSO_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
# REACT_APP_SSO_REDIRECT_URI=http://localhost:3001
