  <diagram name="Input Layer Detail" id="reticle-input-v3">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2300" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="T2_TIT" value="&lt;b&gt;RETICLE — Input Layer: Attributes · File Formats · Domain Context · Phase 1 Mapping&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;align=center;fontColor=#ffffff;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="10" width="2220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T2_INL" value="&lt;b&gt;INPUT LAYER — 6 Inputs: Data Types, Required &amp;amp; Optional Attributes&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#555555;verticalAlign=top;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="2000" height="530" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN1" value="&lt;b&gt;📋&amp;nbsp;INPUT 1: Ranked Gene List&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; CSV · TSV · Excel (.xlsx)&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• gene_symbol&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• score&amp;nbsp;Float&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; rank · fdr · mean_lfc · n_sgrna · condition&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Direct output of CRISPR screen pipeline (MAGeCK/STARS/DRUGz). Each row = one gene target + phenotypic effect magnitude.&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; score → Rank Percentile Normalization · gene_symbol → Gene ID Resolver → Missing Data Taxonomy&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="95" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN2" value="&lt;b&gt;📊&amp;nbsp;INPUT 2: Ranking Metric Spec&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; JSON · Form · CLI flag&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• metric_type&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• positive_means&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• higher_is_hit&amp;nbsp;Boolean&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; algorithm_source · score_scale · cutoff_fdr&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Defines HOW to interpret the score column. Same numeric value means opposite things depending on algorithm, library type, and comparison direction.&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; metric_type + higher_is_hit → Directional Uniformity sign convention resolver · algorithm_source → Score normalizer&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="705" y="95" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN3" value="&lt;b&gt;🔬&amp;nbsp;INPUT 3: Screen Type &amp;amp; Library&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; Enum · JSON · UI form&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• crispr_modality&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• library_name&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• selection_dir&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; organism · library_size · cell_coverage&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Specifies CRISPR biology type. KO/CRISPRa/CRISPRi produce INVERTED phenotypic logic. Selection method &amp;amp; direction govern enrichment vs depletion interpretation.&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; crispr_modality + selection_dir → Directional Uniformity sign flip table · library_size → Rank Percentile denominator&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1365" y="95" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN4" value="&lt;b&gt;🧫&amp;nbsp;INPUT 4: Experimental Context&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; JSON · YAML · Form fields&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• cell_type&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• organism&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• treatment_A&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• treatment_B&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; time_point_hrs · n_replicates · passage_number&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Defines the biological experimental design. Determines which BioGrid ORCS reference screens are semantically relevant. Also sets scope for library coverage check.&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; cell_type + organism → BioGrid ORCS context filter · treatment_A/B → comparison validator → Missing Data Taxonomy scope&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="320" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN5" value="&lt;b&gt;🎯&amp;nbsp;INPUT 5: Query Mode &amp;amp; Scope&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; Enum · UI toggle · CLI argument&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• query_scope&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• comparison_mode&amp;nbsp;Enum&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; top_n · fdr_threshold · direction_filter · sunbeam_zones&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Specifies the scope and resolution of the biological question. Governs which comparison algorithm is invoked: Spearman/Kendall (genome-scale) vs Jaccard/Fisher (subset).&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; query_scope → Algorithm selector in Phase 3 · top_n / fdr_threshold → Pre-filter applied post-normalization&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="705" y="320" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_IN6" value="&lt;b&gt;📁&amp;nbsp;INPUT 6: Comparison Dataset&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Format:&lt;/b&gt; CSV · TSV (same schema as Input 1)&lt;hr/&gt;&lt;b&gt;Required:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• gene_symbol&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• score_cond2&amp;nbsp;Float&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;• condition_label&amp;nbsp;String&amp;nbsp;&lt;b&gt;★&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Optional:&lt;/b&gt; rank_2 · fdr_2 · mean_lfc_2&lt;hr/&gt;&lt;b&gt;Domain:&lt;/b&gt; Optional second ranked gene list for multi-condition residual analysis. Critical for the Irg1/itaconate suppressor screen: IFNγ+TNF+CTA vs CTA alone isolates CTA-specific gene effects.&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt; score_cond2 + Input 1 score → Spline Residual Calculator · both scores → Rank Percentile Normalization&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#888888;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1365" y="320" width="650" height="215" as="geometry" />
        </mxCell>
        <mxCell id="T2_BRG" value="&lt;b&gt;DOMAIN ↔ SOFTWARE BRIDGE — Each input mapped to its domain concept, software component, and Phase 1 target&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#e8ecf0;strokeColor=#4a6fa5;verticalAlign=top;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="605" width="2000" height="195" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR1" value="&lt;b&gt;📋 Input 1&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Gene List&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;Screen phenotype result&lt;br/&gt;(gene → effect magnitude)&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;CSV/TSV parser&lt;br/&gt;Gene ID normalizer&lt;br/&gt;Score ingestion engine&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Rank Percentile Norm&lt;br/&gt;Missing Data Taxonomy&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR2" value="&lt;b&gt;📊 Input 2&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Metric Spec&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;Statistical scoring&lt;br/&gt;convention — what does&lt;br/&gt;+/− score mean?&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;Metric Config Resolver&lt;br/&gt;Direction Lookup&lt;br/&gt;Table Builder&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Directional Uniformity&lt;br/&gt;Rank Percentile Norm&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="375" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR3" value="&lt;b&gt;🔬 Input 3&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Screen Type&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;CRISPR biology type —&lt;br/&gt;KO vs CRISPRa vs&lt;br/&gt;CRISPRi perturbation&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;Library Registry API&lt;br/&gt;Modality Enum mapper&lt;br/&gt;Sign Flip Dispatcher&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Directional Uniformity&lt;br/&gt;(primary driver)&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="705" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR4" value="&lt;b&gt;🧫 Input 4&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Exp Context&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;Experimental design:&lt;br/&gt;cell model, treatment,&lt;br/&gt;organism context&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;Context Schema Validator&lt;br/&gt;BioGrid ORCS filter&lt;br/&gt;Query builder&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Missing Data Taxonomy&lt;br/&gt;+ Context filter&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1035" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR5" value="&lt;b&gt;🎯 Input 5&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Query Mode&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;Research scope —&lt;br/&gt;single gene vs&lt;br/&gt;genome-scale question&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;Query Router&lt;br/&gt;Algorithm Selector&lt;br/&gt;(continuous vs binary)&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Routes to Phase 3&lt;br/&gt;Comparison Engine&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1365" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_BR6" value="&lt;b&gt;📁 Input 6&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Comparison&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Domain:&lt;/b&gt;&lt;br/&gt;Multi-condition data&lt;br/&gt;enabling residual&lt;br/&gt;analysis (Sunbeam)&lt;hr/&gt;&lt;b&gt;Software:&lt;/b&gt;&lt;br/&gt;Second CSV Ingestion&lt;br/&gt;Paired Score Aligner&lt;br/&gt;Spline Engine&lt;hr/&gt;&lt;b&gt;→ Phase 1:&lt;/b&gt;&lt;br/&gt;Rank Percentile (both)&lt;br/&gt;Spline Residual Calc&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#4a6fa5;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1695" y="640" width="320" height="175" as="geometry" />
        </mxCell>
        <mxCell id="T2_P1" value="&lt;b&gt;⚙️  PHASE 1 — Data Harmonization: Typed inputs → unified harmonized scores + 3-state matrix&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="825" width="2000" height="300" as="geometry" />
        </mxCell>
        <mxCell id="T2_P1A" value="&lt;b&gt;🔄 Directional Uniformity&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Receives from:&lt;/b&gt; Input 2: metric_type · positive_means · higher_is_hit&lt;br/&gt;Input 3: crispr_modality · selection_dir · library_name&lt;hr/&gt;&lt;b&gt;Libs:&lt;/b&gt; pandas · numpy · pydantic v2&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~80 lines:&lt;/b&gt;&lt;br/&gt;Maps (modality × selection × algorithm) → ±1 sign rule&lt;br/&gt;KO+viability+depleted → +1 = gene protects cell&lt;br/&gt;CRISPRa+enriched → +1 = gene drives phenotype&lt;br/&gt;Tags each record: direction_verified = True/False&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt; Parquet: harmonized_scores.parquet (gene | adj_score | direction_flag)&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="860" width="650" height="225" as="geometry" />
        </mxCell>
        <mxCell id="T2_P1B" value="&lt;b&gt;📐 Rank Percentile Normalization&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Receives from:&lt;/b&gt; Input 1: score (raw) · gene_symbol&lt;br/&gt;Input 2: algorithm_source · score_scale&lt;br/&gt;Input 3: library_name · library_size&lt;br/&gt;Input 6: score_cond2 (if provided)&lt;hr/&gt;&lt;b&gt;Libs:&lt;/b&gt; scipy.stats (rankdata) · pyarrow · numpy · pandas&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~50 lines wrapper:&lt;/b&gt;&lt;br/&gt;Groups by screen_id; computes within-screen percentile&lt;br/&gt;percentile = rank / library_size × 100 (per screen)&lt;br/&gt;Handles MAGeCK LFC, STARS score, DRUGz z-score&lt;br/&gt;Stores BOTH raw score AND normalised percentile&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt; Parquet: percentiles.parquet (gene | raw_score | percentile | screen_id)&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="705" y="860" width="650" height="225" as="geometry" />
        </mxCell>
        <mxCell id="T2_P1C" value="&lt;b&gt;🗂️ Missing Data Taxonomy&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Receives from:&lt;/b&gt; Input 1: gene_symbol list (user&#39;s screened genes)&lt;br/&gt;Input 3: library_name → BioGrid library lookup&lt;br/&gt;Input 4: cell_type + organism → context filter&lt;hr/&gt;&lt;b&gt;Libs:&lt;/b&gt; scipy.sparse (CSR matrix) · sqlalchemy · requests · diskcache&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~100 lines:&lt;/b&gt;&lt;br/&gt;3-state classification per gene × screen pair:&lt;br/&gt;NOT_IN_LIB (NaN) — gene absent from screen library&lt;br/&gt;IN_LIB_NO_HIT (0) — screened, not significant&lt;br/&gt;IN_LIB_HIT (1) — screened, hit (direction tagged)&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt; SQLite: gene_matrix.db + scipy .npz: sparse_binary_matrix.npz&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" vertex="1" parent="1">
          <mxGeometry x="1365" y="860" width="650" height="225" as="geometry" />
        </mxCell>
        <mxCell id="T2_P1S" value="&lt;b&gt;💾 Phase 1 Storage:&lt;/b&gt;&amp;nbsp; Parquet: harmonized_scores · percentiles&amp;nbsp;|&amp;nbsp; SQLite: gene_matrix.db&amp;nbsp;|&amp;nbsp;scipy .npz: sparse_binary_matrix.npz" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="1078" width="1970" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T2_EXT1" value="&lt;b&gt;🌐 BioGrid ORCS&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;CRISPR screen repository&lt;br/&gt;Library gene lists per screen&lt;br/&gt;→ Phase 1C missing data&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90d9;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2060" y="860" width="210" height="68" as="geometry" />
        </mxCell>
        <mxCell id="T2_EXT2" value="&lt;b&gt;📈 DepMap Portal&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Cancer functional genomics&lt;br/&gt;Reference KO distributions&lt;br/&gt;→ Phase 1B normalization&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90d9;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="2060" y="940" width="210" height="68" as="geometry" />
        </mxCell>
        <mxCell id="T2_DS" value="&lt;b&gt;Downstream pipeline — see E2E Workflow tab for full detail&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#aaaaaa;verticalAlign=top;fontStyle=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="1155" width="2000" height="80" as="geometry" />
        </mxCell>
        <mxCell id="T2_DS1" value="🤖 Phase 2&lt;br/&gt;LLM Curation" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=middle;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="45" y="1185" width="386" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T2_DS2" value="🔍 Phase 3&lt;br/&gt;Comparison" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=middle;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="441" y="1185" width="386" height="42" as="geometry" />
