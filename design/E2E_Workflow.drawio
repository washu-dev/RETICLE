  <diagram name="Software Stack &amp; Storage" id="reticle-stack-v2">
    <mxGraphModel dx="1674" dy="907" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2300" pageHeight="2050" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="T3_TIT" value="&lt;b&gt;RETICLE — Python Library Stack · Custom Algorithms · Storage Architecture (per component)&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;align=center;fontColor=#ffffff;fontSize=13;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="10" width="2230" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T3_P1" value="&lt;b&gt;⚙️  PHASE 1 — Data Harmonization&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="60" width="2230" height="310" as="geometry" />
        </mxCell>
        <mxCell id="T3_P1_A" value="&lt;b&gt;🔄 Directional Uniformity&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• pandas ≥2.0 (apply, map, vectorised ops)&lt;br/&gt;• numpy (sign, where, array broadcasting)&lt;br/&gt;• pydantic v2 (input schema validation)&lt;br/&gt;• pytest (unit tests for rule table)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~80 lines:&lt;/b&gt;&lt;br/&gt;Sign convention lookup table:&lt;br/&gt;Maps (modality × selection × algorithm) → ±1&lt;br/&gt;No existing library handles CRISPR sign rules.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Apache Parquet&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; pyarrow · filesystem or S3&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | adj_score | direction_flag | screen_id&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="95" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P1_B" value="&lt;b&gt;📐 Rank Percentile Normalization&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• scipy.stats (rankdata, percentileofscore)&lt;br/&gt;• numpy (argsort, percentile, broadcasting)&lt;br/&gt;• pandas ≥2.0 (groupby per screen_id)&lt;br/&gt;• pyarrow ≥14.0 (fast Parquet I/O)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~50-line wrapper:&lt;/b&gt;&lt;br/&gt;scipy.stats.rankdata per screen group;&lt;br/&gt;percentile = rank / library_size × 100.&lt;br/&gt;Custom: loop wrapper + library-size lookup.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Apache Parquet&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; pyarrow · filesystem / S3&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | raw_score | percentile | screen_id | lib_size&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="781" y="95" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P1_C" value="&lt;b&gt;🗂️ Missing Data Taxonomy&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• pandas ≥2.0 (pivot_table, merge, isin)&lt;br/&gt;• scipy.sparse (CSR matrix for gene×screen)&lt;br/&gt;• sqlalchemy ≥2.0 (SQLite ORM)&lt;br/&gt;• requests + diskcache (BioGrid API + cache)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~100 lines:&lt;/b&gt;&lt;br/&gt;3-state classifier: NOT_IN_LIB / NO_HIT / HIT.&lt;br/&gt;Queries BioGrid ORCS library gene lists via API.&lt;br/&gt;Builds sparse gene×screen binary matrix.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; SQLite + scipy .npz&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; gene_matrix.db + sparse_matrix.npz&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | screen_id | state{0,1,NaN} | direction&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1517" y="95" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P1S" value="&lt;b&gt;💾&lt;/b&gt;&amp;nbsp; Parquet: harmonized_scores · percentiles  |  SQLite: gene_matrix.db  |  scipy .npz: sparse_binary_matrix.npz" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="323" width="2200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T3_P2" value="&lt;b&gt;🤖  PHASE 2 — LLM Metadata Curation&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="395" width="2230" height="310" as="geometry" />
        </mxCell>
        <mxCell id="T3_P2_A" value="&lt;b&gt;📄 PMID Fetch &amp;amp; Methods Extract&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• biopython (Bio.Entrez: esearch, efetch)&lt;br/&gt;• metapub (structured PubMed article objects)&lt;br/&gt;• requests + tenacity (retry: ≤3 req/sec)&lt;br/&gt;• beautifulsoup4 + lxml (HTML/XML parsing)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~80 lines:&lt;/b&gt;&lt;br/&gt;Fetch PMC XML; extract sec-type=methods.&lt;br/&gt;Fallback: abstract (~30% of papers).&lt;br/&gt;tenacity handles NCBI rate-limit retries.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; JSON files&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; MongoDB (pmid_methods collection)&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; pmid | screen_id | methods_text | title | year&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="430" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P2_B" value="&lt;b&gt;🧠 LLM Parser + Schema Validation&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• anthropic ≥0.30 (Claude Sonnet)&lt;br/&gt;• instructor ≥1.0 (JSON-mode enforcement)&lt;br/&gt;• pydantic v2 (ScreenMetadata model)&lt;br/&gt;• tiktoken (token counting + chunking)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~150 lines:&lt;/b&gt;&lt;br/&gt;ScreenMetadata Pydantic model enforced by instructor.&lt;br/&gt;Fields: screen_type · selection · control_cmp · algorithm.&lt;br/&gt;Confidence score generated per extracted field.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; JSON → PostgreSQL JSONB&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; PostgreSQL screen_metadata (JSONB)&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; screen_id | metadata_jsonb | llm_confidence | timestamp&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="781" y="430" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P2_C" value="&lt;b&gt;👤 Human-in-the-Loop Dashboard&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• streamlit ≥1.35 (web review UI)&lt;br/&gt;• sqlalchemy ≥2.0 (ORM reads/writes)&lt;br/&gt;• alembic (schema migrations)&lt;br/&gt;• pandas (data display + inline editing)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~300 lines:&lt;/b&gt;&lt;br/&gt;PENDING → IN_REVIEW → APPROVED/REJECTED states.&lt;br/&gt;LLM output + methods text side-by-side diff view.&lt;br/&gt;Audit log: reviewer · timestamp · changed fields.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; PostgreSQL&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; screen_metadata (approved) + audit_log table&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; screen_id | approved_by | reviewed_at | changes_json&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1517" y="430" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P2S" value="&lt;b&gt;💾&lt;/b&gt;&amp;nbsp; MongoDB: raw methods JSON  →  LLM  →  PostgreSQL JSONB: screen_metadata (screen_type · selection · algorithm · approved_by)" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="658" width="2200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T3_P3" value="&lt;b&gt;🔍  PHASE 3 — Comparison Engine&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="730" width="2230" height="310" as="geometry" />
        </mxCell>
        <mxCell id="T3_P3_A" value="&lt;b&gt;📉 Continuous / Rank Mode&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• scipy.stats (spearmanr, kendalltau, rankdata)&lt;br/&gt;• scipy.interpolate (UnivariateSpline — residuals)&lt;br/&gt;• numpy (vectorised pairwise broadcasting)&lt;br/&gt;• numba (JIT compile) + joblib (parallelism)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~200 lines (key algorithm):&lt;/b&gt;&lt;br/&gt;Spline Residual Calculator:&lt;br/&gt;1. Fit cubic spline to (score_cond1, score_cond2).&lt;br/&gt;2. residual = actual_Y − spline_predicted_Y.&lt;br/&gt;3. Residual → Sunbeam zone classification (8 cats).&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Parquet + Redis&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; Parquet: spearman_matrix · Redis: top-K cache (TTL=24h)&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; query_hash | screen_id | rho | pval | residual&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="765" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P3_B" value="&lt;b&gt;🎯 Binary / Overlap Mode&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• scipy.stats (fisher_exact, hypergeom.sf)&lt;br/&gt;• scikit-learn (jaccard_score)&lt;br/&gt;• statsmodels (multipletests: BH FDR)&lt;br/&gt;• numpy (intersect1d, union1d — set ops)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~120-line loop wrapper:&lt;/b&gt;&lt;br/&gt;Build 0/1 matrix from Phase 1C output.&lt;br/&gt;Jaccard: |A∩B| / |A∪B| per screen pair.&lt;br/&gt;BH FDR correction across all screen comparisons.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Apache Parquet&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; Parquet: jaccard_fisher_results&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; screen_id | jaccard | fisher_pval | fdr | overlap_genes&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="781" y="765" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P3_C" value="&lt;b&gt;🔗 External Tool Integrations&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• gseapy ≥1.0 (Enrichr API + GSEA preranked)&lt;br/&gt;• stringdb (STRING DB Python client)&lt;br/&gt;• mygene ≥3.2 (gene ID mapping: symbol→Entrez)&lt;br/&gt;• networkx (PPI graph analysis + centrality)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~100-line adapter:&lt;/b&gt;&lt;br/&gt;Normalise output schemas from STRING/ENRICHr/GSEA&lt;br/&gt;into unified: term | pval | fdr | genes | source.&lt;br/&gt;Custom: adapter layer only; APIs fully existing.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; JSON + PostgreSQL&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; PostgreSQL: enrichment_results + JSON cache&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; query_id | tool | term_name | pval | fdr | gene_list&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1517" y="765" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P3S" value="&lt;b&gt;💾&lt;/b&gt;&amp;nbsp; Parquet: spearman_matrix · jaccard_results  |  Redis: top-K cache (TTL=24h)  |  PostgreSQL: enrichment_results" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="993" width="2200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4" value="&lt;b&gt;🌑  PHASE 4 — Dark Matter Illumination&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="1065" width="2230" height="310" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4_A" value="&lt;b&gt;📰 PubMed Count&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• biopython (Bio.Entrez.esearch)&lt;br/&gt;• diskcache (30-day TTL per gene)&lt;br/&gt;• tenacity (rate-limit retry)&lt;br/&gt;• tqdm (batch progress)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~60 lines:&lt;/b&gt;&lt;br/&gt;NCBI eUtils esearch per gene symbol.&lt;br/&gt;Cache to avoid re-querying known genes.&lt;br/&gt;Batch mode for full gene list processing.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; SQLite&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; gene_knowledge.db&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | pub_count | last_updated&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="1100" width="542" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4_B" value="&lt;b&gt;🧬 GO Annotation Density&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• mygene ≥3.2 (GO term fetch per gene)&lt;br/&gt;• goatools (GO DAG traversal)&lt;br/&gt;• pronto (OBO format parser)&lt;br/&gt;• diskcache (GO term cache)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~100 lines:&lt;/b&gt;&lt;br/&gt;Fetch GO terms per gene via mygene API.&lt;br/&gt;Filter: keep only depth ≥ 3 in GO DAG.&lt;br/&gt;Excludes generic terms (e.g. &#39;protein binding&#39;).&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; SQLite&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; gene_knowledge.db (gene_go_annotations table)&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | n_total_go | n_specific_go | depth_median&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="597" y="1100" width="542" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4_C" value="&lt;b&gt;⭐ Darkness Rating Calculator&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• pandas ≥2.0 (join Phase 4A+4B outputs)&lt;br/&gt;• numpy (weighted sum + log transform)&lt;br/&gt;• scikit-learn (MinMaxScaler 0–10)&lt;br/&gt;• pyyaml (configurable weight file)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~50 lines (custom formula):&lt;/b&gt;&lt;br/&gt;darkness = w1/(log(pub+1)) + w2/(go+1) + w3/(hits+1)&lt;br/&gt;MinMaxScaler → 0.0 (known) to 10.0 (dark).&lt;br/&gt;Weights configurable via YAML (w1=0.4 w2=0.4 w3=0.2).&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Parquet&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; darkness_scores.parquet · SQLite lookup&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | darkness_score | pub_count | n_go | n_hits&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1149" y="1100" width="542" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4_D" value="&lt;b&gt;💡 Dark Candidate Surface&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• pandas ≥2.0 (merge darkness + enrichment)&lt;br/&gt;• numpy (quadrant scoring X×Y)&lt;br/&gt;• plotly ≥5.0 (interactive scatter chart)&lt;br/&gt;• scipy.stats (Spearman ranking)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;✅ Existing libs — ~80 lines:&lt;/b&gt;&lt;br/&gt;2-axis scoring: X = pathway corr (Phase 3 rho);&lt;br/&gt;Y = darkness rating (Phase 4C score 0–10).&lt;br/&gt;Rank by composite_score = X × Y; output top-N.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; Parquet + JSON&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; dark_candidates.parquet + top_N_candidates.json&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene_symbol | darkness | pathway_corr | rank | evidence&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1701" y="1100" width="542" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P4S" value="&lt;b&gt;💾&lt;/b&gt;&amp;nbsp; SQLite: gene_knowledge.db (pub_count + GO scores)  |  Parquet: darkness_scores.parquet  |  JSON: top_N_candidates" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="1328" width="2200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T3_P5" value="&lt;b&gt;🤖  PHASE 5 — AI Hypothesis Engine&lt;/b&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="30" y="1400" width="2230" height="310" as="geometry" />
        </mxCell>
        <mxCell id="T3_P5_A" value="&lt;b&gt;🔎 RAG Literature Search&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• langchain ≥0.2 (RAG pipeline + retriever)&lt;br/&gt;• chromadb ≥0.5 (local persistent vector store)&lt;br/&gt;• sentence-transformers (BioBERT embeddings)&lt;br/&gt;• biopython (PubMed abstract bulk fetch)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~200 lines:&lt;/b&gt;&lt;br/&gt;BioBERT embeddings (biomedical domain-specific).&lt;br/&gt;512-token chunks + 50-token overlap from abstracts.&lt;br/&gt;Query: function of {gene} in {cell_type}+{treatment}.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; ChromaDB vector store&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; ./chroma_db/ local OR Pinecone cloud&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; embedding | gene_symbol | pmid | text_chunk | year&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="1435" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P5_B" value="&lt;b&gt;⚗️ Hypothesis Generator&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• anthropic ≥0.30 (Claude Sonnet)&lt;br/&gt;• instructor ≥1.0 (Pydantic JSON enforcement)&lt;br/&gt;• pydantic v2 (Hypothesis + Evidence schemas)&lt;br/&gt;• langchain (RAGChain: context → LLM)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~150 lines:&lt;/b&gt;&lt;br/&gt;Hypothesis schema: mechanism · confidence (0–1)&lt;br/&gt;· testable_prediction · suggested_assay.&lt;br/&gt;instructor enforces JSON output matching schema.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; JSON files&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; hypotheses/{gene}_{screen_id}.json · versioned&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; gene | mechanism | confidence | prediction | pmids&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="781" y="1435" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P5_C" value="&lt;b&gt;📝 Report Formatter&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;📦 Libraries:&lt;/b&gt;&lt;br/&gt;• jinja2 ≥3.1 (HTML + Markdown templates)&lt;br/&gt;• weasyprint (HTML → print-quality PDF)&lt;br/&gt;• plotly ≥5.0 (charts → static PNG for PDF)&lt;br/&gt;• pandas (tabular formatting + export)&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;🔧 Custom — ~200 lines:&lt;/b&gt;&lt;br/&gt;5-section Jinja2 template: 1. Summary 2. Gene table&lt;br/&gt;3. Dark candidates 4. AI hypotheses 5. Validation.&lt;br/&gt;HTML first → WeasyPrint → PDF with embedded charts.&lt;hr/&gt;&lt;b&gt;💾 Output:&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Format:&lt;/b&gt; PDF + HTML&lt;br/&gt;&lt;b&gt;Store:&lt;/b&gt; reports/{session_id}/ — versioned output dirs&lt;br/&gt;&lt;b&gt;Schema:&lt;/b&gt; session_id | genes_analyzed | top_screens | candidates&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="1517" y="1435" width="726" height="200" as="geometry" />
        </mxCell>
        <mxCell id="T3_P5S" value="&lt;b&gt;💾&lt;/b&gt;&amp;nbsp; ChromaDB: ./chroma_db/ (BioBERT vectors)  |  JSON: hypotheses/{gene}.json  |  PDF+HTML: reports/{session_id}/" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=middle;align=left;" parent="1" vertex="1">
          <mxGeometry x="45" y="1663" width="2200" height="38" as="geometry" />
        </mxCell>
        <mxCell id="T3_STOR" value="&lt;b&gt;💾  STORAGE ARCHITECTURE — Technology Decision Matrix&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;&lt;font color=&#39;#00aa44&#39;&gt;Apache Parquet&lt;/font&gt;&lt;/b&gt;  —  Phase 1 harmonized scores · Phase 3 comparison matrix · Phase 4 darkness scores&lt;br/&gt;  pyarrow / pandas.to_parquet() · columnar format · fast analytical reads · portable&lt;br/&gt;  Files: harmonized_scores · percentiles · spearman_matrix · jaccard_results · darkness_scores&lt;br/&gt;&lt;br/&gt;&lt;b&gt;&lt;font color=&#39;#0066cc&#39;&gt;SQLite&lt;/font&gt;&lt;/b&gt;  —  Gene knowledge layer (Phase 4) · Gene×Screen 3-state matrix (Phase 1C)&lt;br/&gt;  sqlalchemy ≥2.0 / sqlite3 · zero-config · portable · ideal for ≤50M rows · nightly refresh&lt;br/&gt;  DBs: gene_knowledge.db (pub_count + GO) · gene_matrix.db (3-state binary matrix)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;&lt;font color=&#39;#cc4400&#39;&gt;PostgreSQL + JSONB&lt;/font&gt;&lt;/b&gt;  —  Master annotated screen DB (Phase 2) · enrichment results (Phase 3)&lt;br/&gt;  sqlalchemy + alembic · JSONB for flexible metadata · pg_trgm for full-text search on methods text&lt;br/&gt;&lt;br/&gt;&lt;b&gt;&lt;font color=&#39;#6600cc&#39;&gt;ChromaDB / FAISS&lt;/font&gt;&lt;/b&gt;  —  RAG vector store (Phase 5 — literature embeddings)&lt;br/&gt;  chromadb local · BioBERT embeddings · semantic similarity search · Pinecone for cloud deployment&lt;br/&gt;&lt;br/&gt;&lt;b&gt;&lt;font color=&#39;#cc6600&#39;&gt;Redis&lt;/font&gt;&lt;/b&gt;  —  Session cache · Spearman top-K hot results (Phase 3 · TTL=24h)&lt;br/&gt;  redis-py · sub-millisecond K-V reads · TTL-based expiry&lt;br/&gt;&lt;br/&gt;&lt;b&gt;&lt;font color=&#39;#006644&#39;&gt;MongoDB&lt;/font&gt;&lt;/b&gt;  —  Raw methods text (Phase 2 PMID fetch output) · pre-LLM extraction staging&lt;br/&gt;  pymongo · flexible JSON documents · text indexing on methods_text field&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#1e2a3a;strokeColor=#0f3460;fontColor=#e8f4f8;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
          <mxGeometry x="30" y="1725" width="2000" height="230" as="geometry" />
        </mxCell>
        <mxCell id="T3_LOC" value="&lt;b&gt;Custom Code Estimates&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Phase 1:  ~230 lines&lt;br/&gt;Phase 2:  ~530 lines&lt;br/&gt;Phase 3:  ~420 lines&lt;br/&gt;Phase 4:  ~290 lines&lt;br/&gt;Phase 5:  ~550 lines&lt;br/&gt;──────────────&lt;br/&gt;&lt;b&gt;Total: ~2,020 lines&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;✅&lt;/b&gt; Existing library&lt;br/&gt;&lt;b&gt;🔧&lt;/b&gt; Custom required&lt;br/&gt;&lt;br/&gt;Est. existing lib calls:&lt;br/&gt;~25 packages total&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
