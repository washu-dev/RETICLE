        <mxCell id="T2_DS3" value="🌑 Phase 4&lt;br/&gt;Dark Matter" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=middle;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="837" y="1185" width="386" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T2_DS4" value="🤖 Phase 5&lt;br/&gt;AI Engine" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=middle;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1233" y="1185" width="386" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T2_DS5" value="📤 Output&lt;br/&gt;Reports" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#aaaaaa;fontSize=9;verticalAlign=middle;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1629" y="1185" width="386" height="42" as="geometry" />
        </mxCell>
        <mxCell id="T2_EM1" value="attribute mapping" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2.5;strokeColor=#333333;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="T2_INL" target="T2_BRG" parent="1">
