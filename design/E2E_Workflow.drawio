        <mxCell id="O2" value="&lt;b&gt;🔗 Screen Comparison&lt;/b&gt;&lt;hr/&gt;&lt;font style=&quot;font-size:9px;color:#222222&quot;&gt;Most similar screens&lt;br/&gt;Ranked by Spearman ρ&lt;br/&gt;Sunbeam zone labels&lt;br/&gt;&lt;/font&gt;" style="rounded=1;arcSize=3;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=9;verticalAlign=top;align=left;" parent="1" vertex="1">
